# =============================================================================
# web-chat — пример конфигурации
# Скопируйте: cp .env.example .env
# PUBLIC_BASE_URL должен совпадать с URL в браузере (критично для картинок!)
# =============================================================================

# --- HTTP-сервер ---
WEB_HOST=0.0.0.0
WEB_PORT=8090
# Встроенный MCP (streamable-http); 0 = WEB_PORT + 1
MCP_PORT=8091
# Базовый URL в LAN (и для LLM vision — хост LLM должен достучаться до этого адреса)
PUBLIC_BASE_URL=http://192.168.88.44:8090
# Опционально: URL при доступе через WireGuard (10.99.99.0/24)
PUBLIC_BASE_URL_VPN=http://10.99.99.9:8090

# Часовой пояс в интерфейсе: Europe/Moscow или пусто = авто (часовой пояс браузера)
DISPLAY_TIMEZONE=Europe/Moscow

# --- LLM (OpenAI-compatible API) ---
LLM_BASE_URL=http://192.168.88.41:8989/v1
LLM_API_KEY=
# Имя модели (рекомендуется задать — иначе при каждом ходе GET /v1/models)
LLM_MODEL=qwen36-40b-iq4xs-2x5060ti
LLM_TIMEOUT_SEC=300
# Ожидание при 503 Loading model (секунды)
LLM_MODEL_LOAD_WAIT_SEC=120

# --- Stable Diffusion WebUI (Automatic1111 / Forge, флаг --api) ---
SD_WEBUI_URL=http://192.168.88.52:7860
SD_AUTH_USER=
SD_AUTH_PASS=
SD_NEGATIVE_PROMPT=
SD_STEPS=22
SD_SAMPLER=Euler a
SD_SCHEDULE_TYPE=Karras
SD_CFG_SCALE=5.0
SD_WIDTH=1024
SD_HEIGHT=1024
# Таймаут HTTP к SD; MCP_TIMEOUT должен быть больше REQUEST_TIMEOUT
REQUEST_TIMEOUT=600
MCP_TIMEOUT=900

# --- База данных и лимиты ---
DATABASE_URL=sqlite+aiosqlite:///./data/db/web_chat.sqlite
MAX_UPLOAD_MB=25
MAX_UPLOAD_IMAGE_PIXELS=16777216
MAX_PDF_PAGES=500
EXTRACT_TIMEOUT_SEC=120
MAX_FILES_PER_MESSAGE=10
MAX_TOOL_ROUNDS=10
MAX_SAME_TOOL_PER_TURN=3
MAX_HISTORY_MESSAGES=60
MAX_EXTRACT_CHARS=50000

# Vision: llama-server качает image_url по HTTP (~10 MB лимит на LLM)
LLM_VISION_MAX_BYTES=6291456
LLM_VISION_JPEG_QUALITY=88
LLM_VISION_MAX_SIDE_PX=4096

# --- pytest: безопасная очистка (см. TODO.md §14.4) ---
# Live HTTP: только WEB_CHAT_TEST_BASE_URL (отдельный dev-инстанс, не production!)
# WEB_CHAT_TEST_BASE_URL=http://127.0.0.1:8099
# WEB_CHAT_TEST_API_KEY=
# WEB_CHAT_TEST_CLEANUP=1
# Очистка через PUBLIC_BASE_URL (осторожно!) — нужны оба флага:
# WEB_CHAT_TEST_CLEANUP_LIVE=1
# WEB_CHAT_TEST_ALLOW_PUBLIC_CLEANUP=1
# Сироты на live («Новая беседа», «t») — только с явным BASE_URL:
# WEB_CHAT_TEST_CLEANUP_ORPHANS=1

# --- Доступ (см. SECURITY.md, TODO-2 P0) ---
# Пусто = без проверки ключа (только доверенная LAN)
API_ACCESS_KEY=
# Origin для WebSocket, через запятую; пусто = не проверять
TRUSTED_WS_ORIGINS=
# IP reverse proxy для X-Forwarded-For
TRUSTED_PROXY_IPS=
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SEC=60

# --- Retention (фоновая очистка + timer) ---
UPLOAD_RETENTION_DAYS=7
GENERATED_RETENTION_DAYS=30

# --- Журнал сервера (файл + панель «Логи» в UI) ---
LOG_FILE=logs/web-chat.log
LOG_LEVEL=INFO
