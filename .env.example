# --- Сервер web-chat ---
WEB_HOST=0.0.0.0
WEB_PORT=8090
MCP_PORT=8091
# URL, который видит браузер пользователя (критично для картинок!)
PUBLIC_BASE_URL=http://192.168.88.44:8090

# --- LLM ---
LLM_BASE_URL=http://192.168.88.41:8989/v1
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SEC=300

# --- Stable Diffusion WebUI ---
SD_WEBUI_URL=http://192.168.88.52:7860
SD_AUTH_USER=
SD_AUTH_PASS=
SD_NEGATIVE_PROMPT=
SD_STEPS=22
SD_SAMPLER=Euler a
SD_SCHEDULE_TYPE=Karras
SD_CFG_SCALE=5.0
SD_WIDTH=1024
SD_HEIGHT=1024
REQUEST_TIMEOUT=600
MCP_TIMEOUT=900

# --- БД и лимиты ---
DATABASE_URL=sqlite+aiosqlite:///./data/db/web_chat.sqlite
MAX_UPLOAD_MB=25
MAX_FILES_PER_MESSAGE=10
MAX_TOOL_ROUNDS=10
MAX_HISTORY_MESSAGES=60
MAX_EXTRACT_CHARS=50000

# --- Хранение ---
UPLOAD_RETENTION_DAYS=7
GENERATED_RETENTION_DAYS=30
